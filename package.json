{
  "name": "afristory",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently -k -n backend,frontend -c green,blue \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "ng serve --proxy-config proxy.conf.json",
    "start:backend": "npm --prefix backend run dev",
    "start:backend:prod": "node backend/dist/index.js",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "ng build",
    "build:backend": "npm --prefix backend run build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "lint": "echo \"No lint configuration yet\""
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@angular/animations": "^20.2.0",
    "@angular/common": "^20.2.0",
    "@angular/compiler": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0",
    "@angular/platform-browser": "^20.2.0",
    "@angular/platform-browser-dynamic": "^20.2.0",
    "@angular/router": "^20.2.0",
    "@angular/service-worker": "^20.2.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zod": "^4.0.14",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.2.0",
    "@angular/cli": "^20.2.0",
    "@angular/compiler-cli": "^20.2.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3"
  }
}
